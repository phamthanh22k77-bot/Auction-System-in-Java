<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!--
    SellerDashboard.fxml
    Controller: client.controllers.SellerDashboardController

    Layout theo mau Seller Hub:
      TOP    : Header (logo, tim kiem, thong bao, user)
      LEFT   : Sidebar nav (Tong quan, Don hang, San pham, Hieu suat, Shop)
      CENTER : StackPane chua 3 pane
        paneOverview : stat cards + don hang cho xu ly + LineChart doanh thu + ho so shop
        paneProducts : form them/sua + table san pham
        paneOrders   : table don hang

    LineChart:
      fx:id="chartRevenue"  — dung voi BidPriceLineChart trong Controller:
        BidPriceLineChart revenueChart = new BidPriceLineChart(chartRevenue, axisWeek, axisRevenue);
        revenueChart.addBidPoint("T2", 1_500_000);
-->

<BorderPane
    prefHeight="720.0" prefWidth="1100.0"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="client.controllers.SellerDashboardController"
    style="-fx-background-color: #F5F6FA;">

    <!-- ══ TOP BAR ══════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #FFFFFF;
                     -fx-padding: 10 24;
                     -fx-border-color: #E8ECF0; -fx-border-width: 0 0 1 0;
                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),4,0,0,2);">

            <!-- Logo -->
            <Label text="AUCTION PRO"
                   style="-fx-text-fill: #2C3E50; -fx-font-size: 16; -fx-font-weight: bold;"/>
            <Label text="Seller Hub"
                   style="-fx-text-fill: #95A5A6; -fx-font-size: 12;"/>

            <!-- Tim kiem -->
            <TextField fx:id="txtGlobalSearch"
                       promptText="Tìm kiếm sản phẩm, đơn hàng..."
                       prefWidth="300" prefHeight="34"
                       onAction="#handleGlobalSearch"
                       style="-fx-background-color: #F5F6FA;
                              -fx-border-color: #DDE1E7; -fx-border-radius: 20;
                              -fx-background-radius: 20; -fx-padding: 6 14; -fx-font-size: 13;"
                       HBox.hgrow="ALWAYS"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Thong bao + user -->
            <Button text="🔔" onAction="#handleNotify"
                    style="-fx-background-color: #F0F3F7; -fx-background-radius: 20;
                           -fx-cursor: hand; -fx-padding: 6 12; -fx-font-size: 14;"/>

            <Button fx:id="btnSellerUser"
                    text="👤 Nguyen Van A"
                    onAction="#handleLogout"
                    style="-fx-background-color: transparent; -fx-text-fill: #2C3E50;
                           -fx-cursor: hand; -fx-font-size: 13;"/>
        </HBox>
    </top>

    <!-- ══ LEFT SIDEBAR ══════════════════════════════════════ -->
    <left>
        <VBox prefWidth="190" spacing="2"
              style="-fx-background-color: #FFFFFF;
                     -fx-padding: 20 10;
                     -fx-border-color: #E8ECF0; -fx-border-width: 0 1 0 0;">

            <!-- Nut tao danh sach moi -->
            <Button maxWidth="Infinity"
                    text="+ Tạo danh sách mới"
                    onAction="#handleNew"
                    style="-fx-background-color: #27AE60; -fx-text-fill: white;
                           -fx-background-radius: 8; -fx-cursor: hand;
                           -fx-padding: 10 14; -fx-font-size: 13; -fx-font-weight: bold;
                           -fx-margin: 0 0 12 0;"/>

            <Region prefHeight="8"/>

            <!-- Nav buttons -->
            <Button fx:id="btnNavOverview" maxWidth="Infinity" onAction="#handleSellerNav"
                    text="📊  Tổng quan"
                    style="-fx-background-color: #EBF5FB; -fx-text-fill: #1A5276;
                           -fx-alignment: CENTER_LEFT; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-padding: 10 14; -fx-font-size: 13;
                           -fx-font-weight: bold;"/>
            <Button fx:id="btnNavOrders" maxWidth="Infinity" onAction="#handleSellerNav"
                    text="📦  Đơn hàng"
                    style="-fx-background-color: transparent; -fx-text-fill: #5D6D7E;
                           -fx-alignment: CENTER_LEFT; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-padding: 10 14; -fx-font-size: 13;"/>
            <Button fx:id="btnNavProducts" maxWidth="Infinity" onAction="#handleSellerNav"
                    text="🏷  Sản phẩm"
                    style="-fx-background-color: transparent; -fx-text-fill: #5D6D7E;
                           -fx-alignment: CENTER_LEFT; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-padding: 10 14; -fx-font-size: 13;"/>
            <Button fx:id="btnNavStats" maxWidth="Infinity" onAction="#handleSellerNav"
                    text="📈  Hiệu suất"
                    style="-fx-background-color: transparent; -fx-text-fill: #5D6D7E;
                           -fx-alignment: CENTER_LEFT; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-padding: 10 14; -fx-font-size: 13;"/>
            <Button fx:id="btnNavShop" maxWidth="Infinity" onAction="#handleSellerNav"
                    text="🏪  Shop"
                    style="-fx-background-color: transparent; -fx-text-fill: #5D6D7E;
                           -fx-alignment: CENTER_LEFT; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-padding: 10 14; -fx-font-size: 13;"/>

            <Region VBox.vgrow="ALWAYS"/>
            <Separator/>
            <Button maxWidth="Infinity" onAction="#handleLogout"
                    text="Đăng xuất"
                    style="-fx-background-color: transparent; -fx-text-fill: #E74C3C;
                           -fx-alignment: CENTER_LEFT; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-padding: 10 14; -fx-font-size: 13;"/>
        </VBox>
    </left>

    <!-- ══ CENTER — 3 pane ════════════════════════════════════ -->
    <center>
        <StackPane style="-fx-background-color: #F5F6FA; -fx-padding: 20;">

            <!-- ════ PANE OVERVIEW ════ -->
            <VBox fx:id="paneOverview" spacing="16">

                <!-- Dong 1: 3 stat card + Ho so shop -->
                <HBox spacing="16" alignment="TOP_LEFT">

                    <!-- Cot trai: stats + don hang + chart -->
                    <VBox spacing="16" HBox.hgrow="ALWAYS">

                        <!-- 3 Stat cards -->
                        <HBox spacing="14">
                            <!-- Sales -->
                            <VBox spacing="4" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-padding: 16;
                                         -fx-background-radius: 12;
                                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),6,0,0,2);">
                                <Label text="Sales (31 ngày)"
                                       style="-fx-text-fill: #95A5A6; -fx-font-size: 12;"/>
                                <Label fx:id="lblStatSales" text="0"
                                       style="-fx-text-fill: #2C3E50; -fx-font-size: 24;
                                              -fx-font-weight: bold;"/>
                                <Label fx:id="lblStatSalesDelta" text="↑ 0%"
                                       style="-fx-text-fill: #27AE60; -fx-font-size: 11;"/>
                            </VBox>
                            <!-- Orders -->
                            <VBox spacing="4" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-padding: 16;
                                         -fx-background-radius: 12;
                                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),6,0,0,2);">
                                <Label text="Orders"
                                       style="-fx-text-fill: #95A5A6; -fx-font-size: 12;"/>
                                <Label fx:id="lblStatOrders" text="0"
                                       style="-fx-text-fill: #2C3E50; -fx-font-size: 24;
                                              -fx-font-weight: bold;"/>
                                <Label fx:id="lblStatOrdersDelta" text="↑ 0%"
                                       style="-fx-text-fill: #27AE60; -fx-font-size: 11;"/>
                            </VBox>
                            <!-- Revenue -->
                            <VBox spacing="4" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-padding: 16;
                                         -fx-background-radius: 12;
                                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),6,0,0,2);">
                                <Label text="Doanh thu (VND)"
                                       style="-fx-text-fill: #95A5A6; -fx-font-size: 12;"/>
                                <Label fx:id="lblStatRevenue" text="0"
                                       style="-fx-text-fill: #2C3E50; -fx-font-size: 22;
                                              -fx-font-weight: bold;"/>
                                <Label fx:id="lblStatRevenueDelta" text="↓ 0%"
                                       style="-fx-text-fill: #E74C3C; -fx-font-size: 11;"/>
                            </VBox>
                        </HBox>

                        <!-- Don hang can xu ly -->
                        <VBox spacing="10"
                              style="-fx-background-color: white; -fx-padding: 16;
                                     -fx-background-radius: 12;
                                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),6,0,0,2);">
                            <Label text="Đơn hàng cần xử lý"
                                   style="-fx-text-fill: #2C3E50; -fx-font-size: 14;
                                          -fx-font-weight: bold;"/>
                            <HBox spacing="12">
                                <!-- Cho xac nhan -->
                                <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                                      style="-fx-background-color: #FEF9E7; -fx-padding: 14;
                                             -fx-background-radius: 10; -fx-border-color: #F9E79F;
                                             -fx-border-radius: 10;">
                                    <Label text="⏳" style="-fx-font-size: 18;"/>
                                    <Label fx:id="lblOrdersPending" text="0"
                                           style="-fx-text-fill: #D68910; -fx-font-size: 22;
                                                  -fx-font-weight: bold;"/>
                                    <Label text="Chờ xác nhận"
                                           style="-fx-text-fill: #7F8C8D; -fx-font-size: 11;"/>
                                </VBox>
                                <!-- Cho lay hang -->
                                <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                                      style="-fx-background-color: #EBF5FB; -fx-padding: 14;
                                             -fx-background-radius: 10; -fx-border-color: #AED6F1;
                                             -fx-border-radius: 10;">
                                    <Label text="📦" style="-fx-font-size: 18;"/>
                                    <Label fx:id="lblOrdersPickup" text="0"
                                           style="-fx-text-fill: #1A5276; -fx-font-size: 22;
                                                  -fx-font-weight: bold;"/>
                                    <Label text="Chờ lấy hàng"
                                           style="-fx-text-fill: #7F8C8D; -fx-font-size: 11;"/>
                                </VBox>
                                <!-- Da xu ly -->
                                <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                                      style="-fx-background-color: #E9F7EF; -fx-padding: 14;
                                             -fx-background-radius: 10; -fx-border-color: #A9DFBF;
                                             -fx-border-radius: 10;">
                                    <Label text="✅" style="-fx-font-size: 18;"/>
                                    <Label fx:id="lblOrdersDone" text="0"
                                           style="-fx-text-fill: #1E8449; -fx-font-size: 22;
                                                  -fx-font-weight: bold;"/>
                                    <Label text="Đã xử lý"
                                           style="-fx-text-fill: #7F8C8D; -fx-font-size: 11;"/>
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- Bieu do doanh thu — LineChart dung BidPriceLineChart -->
                        <!--
                            Controller su dung:
                              BidPriceLineChart revenueChart =
                                  new BidPriceLineChart(chartRevenue, axisWeek, axisRevenue);
                              revenueChart.setMaxPoints(12);
                              // Them du lieu:
                              revenueChart.addBidPoint("T2", 1_500_000);
                              revenueChart.addBidPoint("T3", 2_100_000);
                        -->
                        <VBox spacing="10"
                              style="-fx-background-color: white; -fx-padding: 16;
                                     -fx-background-radius: 12;
                                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),6,0,0,2);"
                              VBox.vgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT">
                                <Label text="Biểu đồ doanh thu"
                                       style="-fx-text-fill: #2C3E50; -fx-font-size: 14;
                                              -fx-font-weight: bold;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button fx:id="btnChartWeek" text="Tuần"
                                        onAction="#handleChartPeriod"
                                        style="-fx-background-color: #2C3E50; -fx-text-fill: white;
                                               -fx-background-radius: 6; -fx-cursor: hand;
                                               -fx-padding: 4 12; -fx-font-size: 12;"/>
                                <Button fx:id="btnChartMonth" text="Tháng"
                                        onAction="#handleChartPeriod"
                                        style="-fx-background-color: #F0F3F7; -fx-text-fill: #5D6D7E;
                                               -fx-background-radius: 6; -fx-cursor: hand;
                                               -fx-padding: 4 12; -fx-font-size: 12;"/>
                            </HBox>

                            <LineChart fx:id="chartRevenue"
                                       VBox.vgrow="ALWAYS"
                                       prefHeight="220"
                                       animated="true"
                                       style="-fx-background-color: transparent;
                                              -fx-padding: 0;">
                                <xAxis>
                                    <CategoryAxis fx:id="axisWeek"
                                                  label="Thời gian"
                                                  style="-fx-tick-label-fill: #95A5A6;"/>
                                </xAxis>
                                <yAxis>
                                    <NumberAxis fx:id="axisRevenue"
                                                label="Doanh thu (d)"
                                                style="-fx-tick-label-fill: #95A5A6;"/>
                                </yAxis>
                            </LineChart>
                        </VBox>

                    </VBox>

                    <!-- Ho so Shop (cot phai) -->
                    <VBox prefWidth="220" spacing="0"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 12;
                                 -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),6,0,0,2);">

                        <!-- Avatar + ten shop -->
                        <StackPane prefHeight="100"
                                   style="-fx-background-color: #2C3E50;
                                          -fx-background-radius: 12 12 0 0;">
                            <Label text="SHOP"
                                   style="-fx-text-fill: white; -fx-font-size: 28;
                                          -fx-font-weight: bold;"/>
                        </StackPane>

                        <VBox spacing="6" style="-fx-padding: 14;">
                            <Label fx:id="lblShopName" text="Tên Shop Của Bạn"
                                   style="-fx-text-fill: #2C3E50; -fx-font-size: 15;
                                          -fx-font-weight: bold;" wrapText="true"/>
                            <Label fx:id="lblShopCompany" text="Công ty TNHH Đấu Giá"
                                   style="-fx-text-fill: #7F8C8D; -fx-font-size: 12;"/>
                            <Label fx:id="lblShopRating" text="⭐ 4.5 / 5.0 (0 đánh giá)"
                                   style="-fx-text-fill: #F39C12; -fx-font-size: 12;"/>
                            <Label fx:id="lblShopDesc"
                                   text="Chuyên cung cấp hàng hóa đấu giá chất lượng."
                                   wrapText="true"
                                   style="-fx-text-fill: #7F8C8D; -fx-font-size: 11;
                                          -fx-line-spacing: 3;"/>

                            <Separator/>

                            <!-- Stats nho -->
                            <HBox spacing="10">
                                <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                                    <Label fx:id="lblShopTotalItems" text="0"
                                           style="-fx-text-fill: #2C3E50; -fx-font-size: 18;
                                                  -fx-font-weight: bold;"/>
                                    <Label text="Sản phẩm"
                                           style="-fx-text-fill: #95A5A6; -fx-font-size: 10;"/>
                                </VBox>
                                <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                                    <Label fx:id="lblShopTotalSold" text="0"
                                           style="-fx-text-fill: #27AE60; -fx-font-size: 18;
                                                  -fx-font-weight: bold;"/>
                                    <Label text="Đã bán"
                                           style="-fx-text-fill: #95A5A6; -fx-font-size: 10;"/>
                                </VBox>
                            </HBox>

                            <Button maxWidth="Infinity"
                                    text="Thiết lập Shop"
                                    onAction="#handleShopSettings"
                                    style="-fx-background-color: #F5F6FA;
                                           -fx-text-fill: #2C3E50; -fx-cursor: hand;
                                           -fx-background-radius: 8; -fx-padding: 8;
                                           -fx-font-size: 12; -fx-font-weight: bold;
                                           -fx-border-color: #DDE1E7; -fx-border-radius: 8;"/>
                        </VBox>
                    </VBox>

                </HBox>
            </VBox>

            <!-- ════ PANE PRODUCTS ════ -->
            <VBox fx:id="paneProducts" spacing="12" visible="false" managed="false">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Quản lý sản phẩm"
                           style="-fx-text-fill: #2C3E50; -fx-font-size: 18;
                                  -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="txtSearchProduct"
                               promptText="🔍 Tìm sản phẩm..."
                               onAction="#handleSearchProduct"
                               style="-fx-pref-width: 200; -fx-border-color: #DDE1E7;
                                      -fx-border-radius: 6; -fx-background-radius: 6;
                                      -fx-padding: 6 10;"/>
                    <ComboBox fx:id="cmbCategory"
                              promptText="Danh mục"
                              onAction="#handleCategoryChange"
                              style="-fx-background-color: white; -fx-border-color: #DDE1E7;
                                     -fx-border-radius: 6; -fx-background-radius: 6;"/>
                    <Button text="+ Thêm mới" onAction="#handleNew"
                            style="-fx-background-color: #27AE60; -fx-text-fill: white;
                                   -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 7 14;"/>
                </HBox>

                <HBox spacing="16" VBox.vgrow="ALWAYS">
                    <!-- Form them/sua -->
                    <VBox spacing="10" prefWidth="260"
                          style="-fx-background-color: white; -fx-padding: 16;
                                 -fx-background-radius: 12;
                                 -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),6,0,0,2);">
                        <Label fx:id="lblFormTitle" text="Thêm sản phẩm mới"
                               style="-fx-font-size: 14; -fx-font-weight: bold;
                                      -fx-text-fill: #2C3E50;"/>
                        <Separator/>
                        <Label text="Tên sản phẩm *"
                               style="-fx-text-fill: #7F8C8D; -fx-font-size: 12;"/>
                        <TextField fx:id="txtName" promptText="Nhập tên..."
                                   style="-fx-border-color: #DDE1E7; -fx-border-radius: 4;
                                          -fx-background-radius: 4; -fx-padding: 7 10;"/>
                        <Label text="Mô tả"
                               style="-fx-text-fill: #7F8C8D; -fx-font-size: 12;"/>
                        <TextArea fx:id="txtDescription" promptText="Mô tả ngắn..."
                                  prefRowCount="3" wrapText="true"
                                  style="-fx-border-color: #DDE1E7; -fx-border-radius: 4;
                                         -fx-background-radius: 4; -fx-padding: 7 10;"/>

                        <!-- Fields dong theo loai -->
                        <VBox fx:id="vboxElectronics" spacing="6" visible="false" managed="false">
                            <TextField fx:id="txtBrand" promptText="Thương hiệu..."
                                       style="-fx-border-color: #DDE1E7; -fx-border-radius: 4;
                                              -fx-background-radius: 4; -fx-padding: 7 10;"/>
                            <TextField fx:id="txtWarranty" promptText="Bảo hành (tháng)..."
                                       style="-fx-border-color: #DDE1E7; -fx-border-radius: 4;
                                              -fx-background-radius: 4; -fx-padding: 7 10;"/>
                        </VBox>
                        <VBox fx:id="vboxArt" spacing="6" visible="false" managed="false">
                            <TextField fx:id="txtArtist" promptText="Nghệ sĩ..."
                                       style="-fx-border-color: #DDE1E7; -fx-border-radius: 4;
                                              -fx-background-radius: 4; -fx-padding: 7 10;"/>
                            <TextField fx:id="txtMedium" promptText="Chất liệu..."
                                       style="-fx-border-color: #DDE1E7; -fx-border-radius: 4;
                                              -fx-background-radius: 4; -fx-padding: 7 10;"/>
                        </VBox>
                        <VBox fx:id="vboxVehicle" spacing="6" visible="false" managed="false">
                            <TextField fx:id="txtEngineType" promptText="Loại động cơ..."
                                       style="-fx-border-color: #DDE1E7; -fx-border-radius: 4;
                                              -fx-background-radius: 4; -fx-padding: 7 10;"/>
                            <TextField fx:id="txtModelYear" promptText="Năm sản xuất..."
                                       style="-fx-border-color: #DDE1E7; -fx-border-radius: 4;
                                              -fx-background-radius: 4; -fx-padding: 7 10;"/>
                        </VBox>

                        <Label text="Giá khởi điểm (₫) *"
                               style="-fx-text-fill: #7F8C8D; -fx-font-size: 12;"/>
                        <TextField fx:id="txtStartingPrice" promptText="VD: 500000"
                                   style="-fx-border-color: #DDE1E7; -fx-border-radius: 4;
                                          -fx-background-radius: 4; -fx-padding: 7 10;"/>
                        <Label text="Ngày kết thúc *"
                               style="-fx-text-fill: #7F8C8D; -fx-font-size: 12;"/>
                        <DatePicker fx:id="datePicker" maxWidth="Infinity"
                                    style="-fx-border-color: #DDE1E7; -fx-border-radius: 4;"/>

                        <Region VBox.vgrow="ALWAYS"/>
                        <Label fx:id="lblFormError" text="" wrapText="true"
                               style="-fx-text-fill: #E74C3C; -fx-font-size: 12;"/>
                        <HBox spacing="8">
                            <Button fx:id="btnSave" text="💾 Lưu"
                                    onAction="#handleSave"
                                    HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                    style="-fx-background-color: #27AE60; -fx-text-fill: white;
                                           -fx-background-radius: 6; -fx-cursor: hand;
                                           -fx-padding: 9; -fx-font-weight: bold;"/>
                            <Button fx:id="btnCancel" text="Huỷ"
                                    onAction="#handleCancel"
                                    style="-fx-background-color: #F0F3F7; -fx-text-fill: #5D6D7E;
                                           -fx-background-radius: 6; -fx-cursor: hand;
                                           -fx-padding: 9 16;"/>
                        </HBox>
                    </VBox>

                    <!-- Table san pham -->
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <TableView fx:id="tblProducts" VBox.vgrow="ALWAYS"
                                   onMouseClicked="#handleTableClick"
                                   style="-fx-background-color: white;
                                          -fx-border-color: #E8ECF0; -fx-border-radius: 10;
                                          -fx-background-radius: 10;">
                            <columns>
                                <TableColumn fx:id="colItemId"    text="Mã"           prefWidth="80"/>
                                <TableColumn fx:id="colName"      text="Tên SP"        prefWidth="180"/>
                                <TableColumn fx:id="colCat"       text="Danh mục"      prefWidth="110"/>
                                <TableColumn fx:id="colPrice"     text="Giá khởi"      prefWidth="110"/>
                                <TableColumn fx:id="colCurPrice"  text="Giá hiện tại"  prefWidth="120"/>
                                <TableColumn fx:id="colAucStatus" text="Trạng thái"    prefWidth="100"/>
                                <TableColumn fx:id="colActions"   text="Hành động"     prefWidth="130"/>
                            </columns>
                        </TableView>
                        <HBox spacing="20" style="-fx-padding: 4 0 0 0;">
                            <Label fx:id="lblTotalProducts" text="Tổng: 0 sản phẩm"
                                   style="-fx-text-fill: #7F8C8D; -fx-font-size: 12;"/>
                            <Label fx:id="lblActiveAuctions" text="Đang đấu giá: 0"
                                   style="-fx-text-fill: #27AE60; -fx-font-size: 12;
                                          -fx-font-weight: bold;"/>
                            <Label fx:id="lblFinishedAuctions" text="Đã kết thúc: 0"
                                   style="-fx-text-fill: #95A5A6; -fx-font-size: 12;"/>
                        </HBox>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ════ PANE ORDERS ════ -->
            <VBox fx:id="paneOrders" spacing="12" visible="false" managed="false">
                <Label text="Đơn hàng"
                       style="-fx-text-fill: #2C3E50; -fx-font-size: 18; -fx-font-weight: bold;"/>
                <TableView fx:id="tblOrders" VBox.vgrow="ALWAYS"
