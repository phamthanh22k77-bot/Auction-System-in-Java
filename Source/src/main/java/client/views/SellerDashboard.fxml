                                  -fx-border-radius: 10; -fx-background-radius: 10;">
                    <columns>
                        <TableColumn fx:id="colOrdId"     text="Mã đơn"     prefWidth="100"/>
                        <TableColumn fx:id="colOrdItem"   text="Sản phẩm"   prefWidth="200"/>
                        <TableColumn fx:id="colOrdBuyer"  text="Người mua"  prefWidth="140"/>
                        <TableColumn fx:id="colOrdPrice"  text="Giá"        prefWidth="120"/>
                        <TableColumn fx:id="colOrdTime"   text="Thời gian"  prefWidth="150"/>
                        <TableColumn fx:id="colOrdStatus" text="Trạng thái" prefWidth="120"/>
                        <TableColumn fx:id="colOrdAct"    text="Hành động"  prefWidth="120"/>
                    </columns>
                </TableView>
            </VBox>

        </StackPane>
    </center>

</BorderPane>
