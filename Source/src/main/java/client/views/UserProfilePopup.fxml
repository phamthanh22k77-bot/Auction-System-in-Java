<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="300.0" prefHeight="220.0" spacing="15.0" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-background-radius: 10; -fx-border-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 15, 0, 0, 0);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controllers.UserProfilePopupController"> <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <HBox alignment="CENTER_LEFT" spacing="15.0">
         <children>
            <Circle fill="#d6eaf8" radius="30.0" />
            <VBox spacing="3.0">
               <children>
                  <Label fx:id="userNameLabel" text="Nguyen Van A"><font><Font name="System Bold" size="16.0" /></font></Label>
                  <Label text="Hạng: Bạc ⭐" textFill="#7f8c8d" />
               </children>
            </VBox>
         </children>
      </HBox>
      <Separator />
      <VBox spacing="8.0">
         <children>
            <HBox spacing="5.0"><Label text="Email:" textFill="#7f8c8d" /><Label fx:id="userEmailLabel" text="vana@email.com" /></HBox>
            <HBox spacing="5.0"><Label text="Số đơn thành công:" textFill="#7f8c8d" /><Label fx:id="userOrdersCount" text="25 đơn" /></HBox>
         </children>
      </VBox>
      <Separator />
      <Button maxWidth="Double.MAX_VALUE" style="-fx-background-color: #f5f6f7; -fx-text-fill: #e74c3c; -fx-cursor: hand;" text="Đăng xuất" />
   </children>
</VBox>