<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="754.0" prefWidth="953.0" style="-fx-background-color: #F0F2F5;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controllers.AdminDashboardController">

    <!-- ===== TOP BAR ===== -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="64.0" prefWidth="715.0" spacing="16" style="-fx-background-color: #FFE4B5; -fx-padding: 12 24; -fx-border-color: #E2E8F0; -fx-border-width: 0 0 1 0; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">
            <Label text="⚙ AUCTION PRO" textFill="#8a8d85">
            <font>
               <Font name="System Bold" size="20.0" />
            </font></Label>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblAdminName" style="-fx-text-fill: #64748B; -fx-font-size: 13;" text="Admin" />
            <Button fx:id="btnLogout" onAction="#handleLogout" style="-fx-background-color: transparent;                            -fx-text-fill: #EF4444;                            -fx-border-color: #EF4444; -fx-border-radius: 6;                            -fx-background-radius: 6;                            -fx-cursor: hand; -fx-padding: 5 14; -fx-font-size: 12;" text="Đăng xuất" />
        </HBox>
    </top>

    <!-- ===== LEFT SIDEBAR: Navigation ===== -->
    <left>
        <VBox prefWidth="210" spacing="4" style="-fx-background-color: #fdf5e6; -fx-padding: 20 12;">

            <Label style="-fx-text-fill: #64748B; -fx-font-size: 10;                           -fx-font-weight: bold; -fx-padding: 0 4 10 4;" text="ĐIỀU HƯỚNG" />

            <Button fx:id="btnNavOverview" maxWidth="Infinity" onAction="#handleNav" style="-fx-background-color: #3B82F6; -fx-text-fill: white;                            -fx-alignment: CENTER_LEFT; -fx-background-radius: 8;                            -fx-cursor: hand; -fx-padding: 10 14; -fx-font-size: 13;                            -fx-font-weight: bold;" text="📊  Tổng quan" />
            <Button fx:id="btnNavUsers" maxWidth="Infinity" onAction="#handleNav" style="-fx-background-color: transparent; -fx-alignment: CENTER_LEFT; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 10 14; -fx-font-size: 13;" text="👥  Người dùng" />
            <Button fx:id="btnNavAuctions" maxWidth="Infinity" onAction="#handleNav" style="-fx-background-color: transparent; -fx-alignment: CENTER_LEFT; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 10 14; -fx-font-size: 13;" text="🏷  Phiên đấu giá" />
            <Button fx:id="btnNavItems" maxWidth="Infinity" onAction="#handleNav" style="-fx-background-color: transparent; -fx-alignment: CENTER_LEFT; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 10 14; -fx-font-size: 13;" text="📦  Sản phẩm" />
            <Button fx:id="btnNavBids" maxWidth="Infinity" onAction="#handleNav" style="-fx-background-color: transparent; -fx-alignment: CENTER_LEFT; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 10 14; -fx-font-size: 13;" text="💰  Lịch sử bid" />

            <Region VBox.vgrow="ALWAYS" />
            <Separator style="-fx-background-color: #334155;" />
            <Label fx:id="lblServerStatus" style="-fx-text-fill: #4ADE80; -fx-font-size: 12;                           -fx-padding: 8 4 0 4;" text="● Server: Online" />
            <Label fx:id="lblConnections" style="-fx-text-fill: #64748B; -fx-font-size: 11;                           -fx-padding: 0 4 4 4;" text="Kết nối: 0 clients" />
        </VBox>
    </left>

    <!-- ===== CENTER: Content panes ===== -->
    <center>
        <StackPane prefHeight="690.0" prefWidth="658.0" style="-fx-background-color: #F0F2F5; -fx-padding: 20;">

            <!-- ── OVERVIEW pane ───────────────────────────────────── -->
            <VBox fx:id="paneOverview" spacing="16">
                <Label style="-fx-text-fill: #1E293B; -fx-font-size: 16;                               -fx-font-weight: bold;" text="Tổng quan hệ thống" />

                <!-- Stats cards row -->
                <HBox spacing="14">
                    <!-- Users card -->
                    <VBox alignment="CENTER" spacing="6" style="-fx-background-color: white;                                  -fx-padding: 22;                                  -fx-background-radius: 12;                                  -fx-border-color: #E2E8F0; -fx-border-radius: 12;                                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);" HBox.hgrow="ALWAYS">
                        <Label fx:id="lblStatUsers" style="-fx-text-fill: #3B82F6; -fx-font-size: 30;                                       -fx-font-weight: bold;" text="0" />
                        <Label style="-fx-text-fill: #64748B; -fx-font-size: 12;" text="Người dùng" />
                    </VBox>
                    <!-- Auctions card -->
                    <VBox alignment="CENTER" spacing="6" style="-fx-background-color: white;                                  -fx-padding: 22;                                  -fx-background-radius: 12;                                  -fx-border-color: #E2E8F0; -fx-border-radius: 12;                                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);" HBox.hgrow="ALWAYS">
                        <Label fx:id="lblStatAuctions" style="-fx-text-fill: #22C55E; -fx-font-size: 30;                                       -fx-font-weight: bold;" text="0" />
                        <Label style="-fx-text-fill: #64748B; -fx-font-size: 12;" text="Phiên đấu giá" />
                    </VBox>
                    <!-- Items card -->
                    <VBox alignment="CENTER" spacing="6" style="-fx-background-color: white;                                  -fx-padding: 22;                                  -fx-background-radius: 12;                                  -fx-border-color: #E2E8F0; -fx-border-radius: 12;                                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);" HBox.hgrow="ALWAYS">
                        <Label fx:id="lblStatItems" style="-fx-text-fill: #F59E0B; -fx-font-size: 30;                                       -fx-font-weight: bold;" text="0" />
                        <Label style="-fx-text-fill: #64748B; -fx-font-size: 12;" text="Sản phẩm" />
                    </VBox>
                    <!-- Bids card -->
                    <VBox alignment="CENTER" spacing="6" style="-fx-background-color: white;                                  -fx-padding: 22;                                  -fx-background-radius: 12;                                  -fx-border-color: #E2E8F0; -fx-border-radius: 12;                                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);" HBox.hgrow="ALWAYS">
                        <Label fx:id="lblStatBids" style="-fx-text-fill: #F97316; -fx-font-size: 30;                                       -fx-font-weight: bold;" text="0" />
                        <Label style="-fx-text-fill: #64748B; -fx-font-size: 12;" text="Lượt bid" />
                    </VBox>
                </HBox>

                <!-- Recent activity -->
                <VBox spacing="10" style="-fx-background-color: white;                              -fx-padding: 18;                              -fx-background-radius: 12;                              -fx-border-color: #E2E8F0; -fx-border-radius: 12;                              -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT">
                        <Label style="-fx-text-fill: #1E293B; -fx-font-weight: bold;                                       -fx-font-size: 13;" text="Hoạt động gần đây" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#handleRefreshActivity" style="-fx-background-color: #EFF6FF;                                        -fx-text-fill: #3B82F6; -fx-cursor: hand;                                        -fx-background-radius: 6; -fx-padding: 5 12;                                        -fx-font-size: 12;" text="Làm mới" />
                    </HBox>
                    <ListView fx:id="listRecentActivity" style="-fx-background-color: #F8FAFC;                                      -fx-border-color: #E2E8F0;                                      -fx-border-radius: 8;                                      -fx-font-size: 12;" VBox.vgrow="ALWAYS" />
                </VBox>
            </VBox>

            <!-- ── USERS pane ──────────────────────────────────────── -->
            <VBox fx:id="paneUsers" managed="false" spacing="12" visible="false">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label style="-fx-text-fill: #1E293B; -fx-font-size: 16;                                   -fx-font-weight: bold;" text="Quản lý người dùng" />
                    <Region HBox.hgrow="ALWAYS" />
                    <TextField fx:id="txtSearchUser" onAction="#handleSearchUser" promptText="🔍 Tìm user..." style="-fx-pref-width: 200;                                       -fx-background-color: white;                                       -fx-text-fill: #1E293B;                                       -fx-prompt-text-fill: #94A3B8;                                       -fx-border-color: #CBD5E1; -fx-border-radius: 8;                                       -fx-background-radius: 8; -fx-padding: 7 12;" />
                    <ComboBox fx:id="cmbFilterRole" onAction="#handleFilterRole" promptText="Vai trò" style="-fx-background-color: white;                                      -fx-border-color: #CBD5E1;                                      -fx-border-radius: 8; -fx-background-radius: 8;">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Tất cả" />
                                <String fx:value="Bidder" />
                                <String fx:value="Seller" />
                                <String fx:value="Admin" />
                            </FXCollections>
                        </items>
                    </ComboBox>
                </HBox>

                <TableView fx:id="tblUsers" style="-fx-background-color: white;                                   -fx-border-color: #E2E8F0;                                   -fx-border-radius: 10; -fx-background-radius: 10;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colUserId" prefWidth="80" text="ID" />
                        <TableColumn fx:id="colUName" prefWidth="160" text="Username" />
                        <TableColumn fx:id="colEmail" prefWidth="200" text="Email" />
                        <TableColumn fx:id="colRole" prefWidth="100" text="Vai trò" />
                        <TableColumn fx:id="colUserAct" prefWidth="140" text="Hành động" />
                    </columns>
                </TableView>
            </VBox>

            <!-- ── AUCTIONS pane ───────────────────────────────────── -->
            <VBox fx:id="paneAuctions" managed="false" spacing="12" visible="false">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label style="-fx-text-fill: #1E293B; -fx-font-size: 16;                                   -fx-font-weight: bold;" text="Quản lý phiên đấu giá" />
                    <Region HBox.hgrow="ALWAYS" />
                    <ComboBox fx:id="cmbFilterStatus" onAction="#handleFilterStatus" promptText="Trạng thái" style="-fx-background-color: white;                                      -fx-border-color: #CBD5E1;                                      -fx-border-radius: 8; -fx-background-radius: 8;">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Tất cả" />
                                <String fx:value="OPEN" />
                                <String fx:value="RUNNING" />
                                <String fx:value="FINISHED" />
                                <String fx:value="CANCELED" />
                            </FXCollections>
                        </items>
                    </ComboBox>
                </HBox>

                <TableView fx:id="tblAuctions" style="-fx-background-color: white;                                   -fx-border-color: #E2E8F0;                                   -fx-border-radius: 10; -fx-background-radius: 10;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colAucId" prefWidth="80" text="Mã" />
                        <TableColumn fx:id="colAucItem" prefWidth="180" text="Sản phẩm" />
                        <TableColumn fx:id="colAucSeller" prefWidth="130" text="Người bán" />
                        <TableColumn fx:id="colAucCurBid" prefWidth="120" text="Giá cao nhất" />
                        <TableColumn fx:id="colAucEnd" prefWidth="150" text="Kết thúc" />
                        <TableColumn fx:id="colAucStatus" prefWidth="100" text="Trạng thái" />
                        <TableColumn fx:id="colAucActions" prefWidth="120" text="Hành động" />
                    </columns>
                </TableView>
            </VBox>

            <!-- ── ITEMS pane ──────────────────────────────────────── -->
            <VBox fx:id="paneItems" managed="false" spacing="12" visible="false">
                <Label style="-fx-text-fill: #1E293B; -fx-font-size: 16;                               -fx-font-weight: bold;" text="Quản lý sản phẩm" />
                <TableView fx:id="tblItems" style="-fx-background-color: white;                                   -fx-border-color: #E2E8F0;                                   -fx-border-radius: 10; -fx-background-radius: 10;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colItId" prefWidth="80" text="Mã" />
                        <TableColumn fx:id="colItName" prefWidth="200" text="Tên" />
                        <TableColumn fx:id="colItCat" prefWidth="110" text="Danh mục" />
                        <TableColumn fx:id="colItSeller" prefWidth="130" text="Người bán" />
                        <TableColumn fx:id="colItPrice" prefWidth="110" text="Giá khởi" />
                        <TableColumn fx:id="colItActions" prefWidth="120" text="Hành động" />
                    </columns>
                </TableView>
            </VBox>

            <!-- ── BIDS pane ───────────────────────────────────────── -->
            <VBox fx:id="paneBids" managed="false" spacing="12" visible="false">
                <Label style="-fx-text-fill: #1E293B; -fx-font-size: 16;                               -fx-font-weight: bold;" text="Lịch sử đặt giá" />
                <TableView fx:id="tblBids" style="-fx-background-color: white;                                   -fx-border-color: #E2E8F0;                                   -fx-border-radius: 10; -fx-background-radius: 10;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colBidId" prefWidth="100" text="Mã bid" />
                        <TableColumn fx:id="colBidder" prefWidth="140" text="Bidder" />
                        <TableColumn fx:id="colBidAuction" prefWidth="140" text="Phiên" />
                        <TableColumn fx:id="colBidAmount" prefWidth="120" text="Số tiền" />
                        <TableColumn fx:id="colBidTime" prefWidth="160" text="Thời gian" />
                        <TableColumn fx:id="colBidValid" prefWidth="80" text="Hợp lệ" />
                    </columns>
                </TableView>
            </VBox>

        </StackPane>
    </center>

</BorderPane>
