<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<BorderPane
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="controllers.admin.AdminDashboardController"
    style="-fx-background-color: #212121;">

    <!-- ===== TOP BAR ===== -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #1A1A1A; -fx-padding: 12 20;
                     -fx-border-color: #333333; -fx-border-width: 0 0 1 0;">
            <Label text="⚙ AuctionApp — Admin"
                   style="-fx-text-fill: #F5F5F5; -fx-font-size: 17; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblAdminName"
                   text="Admin"
                   style="-fx-text-fill: #9E9E9E; -fx-font-size: 13;"/>
            <Button fx:id="btnLogout" text="Đăng xuất" onAction="#handleLogout"
                    style="-fx-background-color: transparent; -fx-text-fill: #EF9A9A;
                           -fx-border-color: #EF9A9A; -fx-border-radius: 4;
                           -fx-cursor: hand; -fx-padding: 4 12;"/>
        </HBox>
    </top>

    <!-- ===== LEFT SIDEBAR: Navigation ===== -->
    <left>
        <VBox spacing="4" prefWidth="200"
              style="-fx-background-color: #1A1A1A; -fx-padding: 16;
                     -fx-border-color: #333333; -fx-border-width: 0 1 0 0;">

            <Label text="ĐIỀU HƯỚNG"
                   style="-fx-text-fill: #616161; -fx-font-size: 10; -fx-padding: 0 0 8 4;"/>

            <Button fx:id="btnNavOverview" text="📊  Tổng quan"
                    onAction="#handleNav" maxWidth="Infinity"
                    style="-fx-background-color: #2D2D2D; -fx-text-fill: #F5F5F5;
                           -fx-alignment: CENTER_LEFT; -fx-background-radius: 6;
                           -fx-cursor: hand; -fx-padding: 10 14; -fx-font-size: 13;"/>
            <Button fx:id="btnNavUsers" text="👥  Người dùng"
                    onAction="#handleNav" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #BDBDBD;
                           -fx-alignment: CENTER_LEFT; -fx-background-radius: 6;
                           -fx-cursor: hand; -fx-padding: 10 14; -fx-font-size: 13;"/>
            <Button fx:id="btnNavAuctions" text="🏷  Phiên đấu giá"
                    onAction="#handleNav" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #BDBDBD;
                           -fx-alignment: CENTER_LEFT; -fx-background-radius: 6;
                           -fx-cursor: hand; -fx-padding: 10 14; -fx-font-size: 13;"/>
            <Button fx:id="btnNavItems" text="📦  Sản phẩm"
                    onAction="#handleNav" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #BDBDBD;
                           -fx-alignment: CENTER_LEFT; -fx-background-radius: 6;
                           -fx-cursor: hand; -fx-padding: 10 14; -fx-font-size: 13;"/>
            <Button fx:id="btnNavBids" text="💰  Lịch sử bid"
                    onAction="#handleNav" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #BDBDBD;
                           -fx-alignment: CENTER_LEFT; -fx-background-radius: 6;
                           -fx-cursor: hand; -fx-padding: 10 14; -fx-font-size: 13;"/>

            <Region VBox.vgrow="ALWAYS"/>
            <Separator style="-fx-border-color: #333333;"/>
            <Label fx:id="lblServerStatus"
                   text="● Server: Online"
                   style="-fx-text-fill: #4CAF50; -fx-font-size: 12; -fx-padding: 8 4 0 4;"/>
            <Label fx:id="lblConnections"
                   text="Kết nối: 0 clients"
                   style="-fx-text-fill: #757575; -fx-font-size: 11; -fx-padding: 0 4 4 4;"/>
        </VBox>
    </left>

    <!-- ===== CENTER: TabPane (nội dung từng tab) ===== -->
    <center>
        <StackPane style="-fx-background-color: #212121; -fx-padding: 16;">
            <!-- Controller sẽ show/hide các pane tương ứng khi bấm nav -->

            <!-- OVERVIEW pane -->
            <VBox fx:id="paneOverview" spacing="16">
                <Label text="Tổng quan hệ thống"
                       style="-fx-text-fill: #F5F5F5; -fx-font-size: 16; -fx-font-weight: bold;"/>

                <!-- Stats cards row -->
                <HBox spacing="12">
                    <VBox spacing="4" alignment="CENTER" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #2C2C2C; -fx-padding: 20;
                                 -fx-background-radius: 10; -fx-border-color: #3A3A3A;
                                 -fx-border-radius: 10;">
                        <Label fx:id="lblStatUsers" text="0"
                               style="-fx-text-fill: #64B5F6; -fx-font-size: 28; -fx-font-weight: bold;"/>
                        <Label text="Người dùng" style="-fx-text-fill: #757575; -fx-font-size: 12;"/>
                    </VBox>
                    <VBox spacing="4" alignment="CENTER" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #2C2C2C; -fx-padding: 20;
                                 -fx-background-radius: 10; -fx-border-color: #3A3A3A;
                                 -fx-border-radius: 10;">
                        <Label fx:id="lblStatAuctions" text="0"
                               style="-fx-text-fill: #81C784; -fx-font-size: 28; -fx-font-weight: bold;"/>
                        <Label text="Phiên đấu giá" style="-fx-text-fill: #757575; -fx-font-size: 12;"/>
                    </VBox>
                    <VBox spacing="4" alignment="CENTER" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #2C2C2C; -fx-padding: 20;
                                 -fx-background-radius: 10; -fx-border-color: #3A3A3A;
                                 -fx-border-radius: 10;">
                        <Label fx:id="lblStatItems" text="0"
                               style="-fx-text-fill: #FFD54F; -fx-font-size: 28; -fx-font-weight: bold;"/>
                        <Label text="Sản phẩm" style="-fx-text-fill: #757575; -fx-font-size: 12;"/>
                    </VBox>
                    <VBox spacing="4" alignment="CENTER" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #2C2C2C; -fx-padding: 20;
                                 -fx-background-radius: 10; -fx-border-color: #3A3A3A;
                                 -fx-border-radius: 10;">
                        <Label fx:id="lblStatBids" text="0"
                               style="-fx-text-fill: #FF8A65; -fx-font-size: 28; -fx-font-weight: bold;"/>
                        <Label text="Lượt bid" style="-fx-text-fill: #757575; -fx-font-size: 12;"/>
                    </VBox>
                </HBox>

                <!-- Recent activity -->
                <VBox spacing="8" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: #2C2C2C; -fx-padding: 16;
                             -fx-background-radius: 10; -fx-border-color: #3A3A3A;
                             -fx-border-radius: 10;">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Hoạt động gần đây"
                               style="-fx-text-fill: #EEEEEE; -fx-font-weight: bold; -fx-font-size: 13;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Làm mới" onAction="#handleRefreshActivity"
                                style="-fx-background-color: transparent;
                                       -fx-text-fill: #64B5F6; -fx-cursor: hand; -fx-font-size: 12;"/>
                    </HBox>
                    <ListView fx:id="listRecentActivity"
                              VBox.vgrow="ALWAYS"
                              style="-fx-background-color: #1E1E1E; -fx-border-color: #3A3A3A;
                                     -fx-border-radius: 6; -fx-font-size: 12;
                                     -fx-text-fill: #BDBDBD;"/>
                </VBox>
            </VBox>

            <!-- USERS pane -->
            <VBox fx:id="paneUsers" spacing="12" visible="false" managed="false">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Quản lý người dùng"
                           style="-fx-text-fill: #F5F5F5; -fx-font-size: 16; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="txtSearchUser" promptText="🔍 Tìm user..."
                               onAction="#handleSearchUser"
                               style="-fx-pref-width: 200; -fx-background-color: #2C2C2C;
                                      -fx-text-fill: white; -fx-prompt-text-fill: #616161;
                                      -fx-border-color: #424242; -fx-border-radius: 6;
                                      -fx-background-radius: 6; -fx-padding: 6 10;"/>
                    <ComboBox fx:id="cmbFilterRole" promptText="Vai trò"
                              onAction="#handleFilterRole"
                              style="-fx-background-color: #2C2C2C; -fx-border-color: #424242;
                                     -fx-border-radius: 6; -fx-background-radius: 6;">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Tất cả"/>
                                <String fx:value="Bidder"/>
                                <String fx:value="Seller"/>
                                <String fx:value="Admin"/>
                            </FXCollections>
                        </items>
                    </ComboBox>
                </HBox>

                <TableView fx:id="tblUsers"
                           VBox.vgrow="ALWAYS"
                           style="-fx-background-color: #2C2C2C; -fx-border-color: #3A3A3A;
                                  -fx-border-radius: 8; -fx-background-radius: 8;">
                    <columns>
                        <TableColumn fx:id="colUserId"    text="ID"       prefWidth="80"/>
                        <TableColumn fx:id="colUName"     text="Username" prefWidth="160"/>
                        <TableColumn fx:id="colEmail"     text="Email"    prefWidth="200"/>
                        <TableColumn fx:id="colRole"      text="Vai trò"  prefWidth="100"/>
                        <TableColumn fx:id="colUserAct"   text="Hành động" prefWidth="140"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- AUCTIONS pane -->
            <VBox fx:id="paneAuctions" spacing="12" visible="false" managed="false">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Quản lý phiên đấu giá"
                           style="-fx-text-fill: #F5F5F5; -fx-font-size: 16; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="cmbFilterStatus" promptText="Trạng thái"
                              onAction="#handleFilterStatus"
                              style="-fx-background-color: #2C2C2C; -fx-border-color: #424242;
                                     -fx-border-radius: 6; -fx-background-radius: 6;">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Tất cả"/>
                                <String fx:value="OPEN"/>
                                <String fx:value="RUNNING"/>
                                <String fx:value="FINISHED"/>
                                <String fx:value="CANCELED"/>
                            </FXCollections>
                        </items>
                    </ComboBox>
                </HBox>

                <TableView fx:id="tblAuctions"
                           VBox.vgrow="ALWAYS"
                           style="-fx-background-color: #2C2C2C; -fx-border-color: #3A3A3A;
                                  -fx-border-radius: 8; -fx-background-radius: 8;">
                    <columns>
                        <TableColumn fx:id="colAucId"      text="Mã"          prefWidth="80"/>
                        <TableColumn fx:id="colAucItem"    text="Sản phẩm"    prefWidth="180"/>
                        <TableColumn fx:id="colAucSeller"  text="Người bán"   prefWidth="130"/>
                        <TableColumn fx:id="colAucCurBid"  text="Giá cao nhất" prefWidth="120"/>
                        <TableColumn fx:id="colAucEnd"     text="Kết thúc"    prefWidth="150"/>
                        <TableColumn fx:id="colAucStatus"  text="Trạng thái"  prefWidth="100"/>
                        <TableColumn fx:id="colAucActions" text="Hành động"   prefWidth="120"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- ITEMS pane -->
            <VBox fx:id="paneItems" spacing="12" visible="false" managed="false">
                <Label text="Quản lý sản phẩm"
                       style="-fx-text-fill: #F5F5F5; -fx-font-size: 16; -fx-font-weight: bold;"/>
                <TableView fx:id="tblItems"
                           VBox.vgrow="ALWAYS"
                           style="-fx-background-color: #2C2C2C; -fx-border-color: #3A3A3A;
                                  -fx-border-radius: 8; -fx-background-radius: 8;">
                    <columns>
                        <TableColumn fx:id="colItId"      text="Mã"         prefWidth="80"/>
                        <TableColumn fx:id="colItName"    text="Tên"        prefWidth="200"/>
                        <TableColumn fx:id="colItCat"     text="Danh mục"   prefWidth="110"/>
                        <TableColumn fx:id="colItSeller"  text="Người bán"  prefWidth="130"/>
                        <TableColumn fx:id="colItPrice"   text="Giá khởi"   prefWidth="110"/>
                        <TableColumn fx:id="colItActions" text="Hành động"  prefWidth="120"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- BIDS pane -->
            <VBox fx:id="paneBids" spacing="12" visible="false" managed="false">
                <Label text="Lịch sử đặt giá"
                       style="-fx-text-fill: #F5F5F5; -fx-font-size: 16; -fx-font-weight: bold;"/>
                <TableView fx:id="tblBids"
                           VBox.vgrow="ALWAYS"
                           style="-fx-background-color: #2C2C2C; -fx-border-color: #3A3A3A;
                                  -fx-border-radius: 8; -fx-background-radius: 8;">
                    <columns>
                        <TableColumn fx:id="colBidId"      text="Mã bid"    prefWidth="100"/>
                        <TableColumn fx:id="colBidder"     text="Bidder"    prefWidth="140"/>
                        <TableColumn fx:id="colBidAuction" text="Phiên"     prefWidth="140"/>
                        <TableColumn fx:id="colBidAmount"  text="Số tiền"   prefWidth="120"/>
                        <TableColumn fx:id="colBidTime"    text="Thời gian" prefWidth="160"/>
                        <TableColumn fx:id="colBidValid"   text="Hợp lệ"   prefWidth="80"/>
                    </columns>
                </TableView>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
