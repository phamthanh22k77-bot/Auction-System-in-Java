<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<!--
    BidderDashboard.fxml
    Controller: client.controllers.BidderDashboardController

    Cau truc:
      TOP    : Header (logo, nav, gio hang, thong bao, user)
      CENTER : HBox
        LEFT   : ScrollPane
          - Tab loc + Tim kiem
          - Section 1: San pham dang dau gia (6 card: 2 Elec, 2 Art, 2 Vehicles)
          - Section 2: Nha ban hang noi bat (3 seller card)
          - Section 3: Tai san sap dau gia (2 upcoming card)
        RIGHT  : Detail panel (an mac dinh, hien khi click card)
-->

<BorderPane prefHeight="750.0" prefWidth="1200.0" style="-fx-background-color: #f5f6fa;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controllers.BidderDashboardController">

    <!-- ══════════════════════════════════════════════════
         TOP — Header
    ══════════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="64.0" spacing="16.0" style="-fx-background-color: #fff891; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
            <padding><Insets bottom="10.0" left="24.0" right="24.0" top="10.0" /></padding>

            <!-- Logo -->
            <Label text="AUCTION PRO" textFill="#8a8d85">
                <font><Font name="System Bold" size="20.0" /></font>
            </Label>

            <!-- Nav -->
            <Button onAction="#handleHome" style="-fx-background-color: transparent; -fx-cursor: hand;                            -fx-text-fill: #2c3e50;" text="Trang chu">
                <font><Font size="14.0" /></font>
            </Button>
            <Button onAction="#handleSupport" style="-fx-background-color: transparent; -fx-cursor: hand;                            -fx-text-fill: #7f8c8d;" text="Ho tro">
                <font><Font size="14.0" /></font>
            </Button>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Gio hang -->
            <Button onAction="#handleCart" style="-fx-background-color: #f0f3f7; -fx-background-radius: 20;                            -fx-cursor: hand; -fx-text-fill: #2c3e50; -fx-padding: 6 14;" text="Gio hang" />

            <!-- Thong bao -->
            <Button onAction="#handleNotify" style="-fx-background-color: #f0f3f7; -fx-background-radius: 20;                            -fx-cursor: hand; -fx-text-fill: #2c3e50; -fx-padding: 6 14;" text="Thong bao" />

            <!-- Nut User -> mo UserProfilePopup -->
            <Button fx:id="profileButton" onAction="#handleProfileClick" style="-fx-background-color: #3498db; -fx-text-fill: white;                            -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 6 18;" text="User" />
            
            <!-- Nut Dang xuat -->
            <Button onAction="#handleLogout" style="-fx-background-color: #E74C3C; -fx-text-fill: white;                            -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 6 18;                            -fx-font-weight: bold; -fx-font-size: 12;" text="🚪 Đăng xuất" />
        </HBox>
    </top>

    <!-- ══════════════════════════════════════════════════
         CENTER — Content + Detail panel
    ══════════════════════════════════════════════════ -->
    <center>
        <HBox BorderPane.alignment="CENTER">

            <!-- ── LEFT: Toan bo noi dung cuon duoc ─────── -->
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;                                -fx-border-color: transparent;" HBox.hgrow="ALWAYS">
                <VBox spacing="0" style="-fx-background-color: #f5f6fa;">

                    <!-- ── Filter tabs + Search ───────────── -->
                    <VBox spacing="12" style="-fx-background-color: #ffffff;                                  -fx-padding: 16 24 16 24;                                  -fx-border-color: transparent transparent #e8ecf0 transparent;                                  -fx-border-width: 0 0 1 0;">

                        <!-- Tab loc danh muc -->
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Button fx:id="btnTabAll" onAction="#handleCategory" style="-fx-background-color: #2c3e50; -fx-text-fill: white;                                            -fx-background-radius: 20; -fx-cursor: hand;                                            -fx-padding: 6 18; -fx-font-size: 13;" text="Tat ca" />
                            <Button fx:id="btnTabElec" onAction="#handleCategory" style="-fx-background-color: white; -fx-border-color: #dde1e7;                                            -fx-border-radius: 20; -fx-background-radius: 20;                                            -fx-cursor: hand; -fx-padding: 6 18; -fx-font-size: 13;" text="Electronics" />
                            <Button fx:id="btnTabArt" onAction="#handleCategory" style="-fx-background-color: white; -fx-border-color: #dde1e7;                                            -fx-border-radius: 20; -fx-background-radius: 20;                                            -fx-cursor: hand; -fx-padding: 6 18; -fx-font-size: 13;" text="Art" />
                            <Button fx:id="btnTabVehicles" onAction="#handleCategory" style="-fx-background-color: white; -fx-border-color: #dde1e7;                                            -fx-border-radius: 20; -fx-background-radius: 20;                                            -fx-cursor: hand; -fx-padding: 6 18; -fx-font-size: 13;" text="Vehicles" />
                            <Region HBox.hgrow="ALWAYS" />
                            <!-- Tim kiem -->
                            <TextField fx:id="txtSearch" onAction="#handleSearch" prefHeight="36.0" prefWidth="320.0" promptText="Tim kiem san pham..." style="-fx-background-radius: 20; -fx-border-radius: 20;                                               -fx-border-color: #dde1e7; -fx-padding: 6 14;                                               -fx-font-size: 13;" />
                            <Button onAction="#handleFilter" style="-fx-background-color: white; -fx-border-color: #dde1e7;                                            -fx-border-radius: 6; -fx-background-radius: 6;                                            -fx-cursor: hand; -fx-padding: 6 14; -fx-font-size: 13;" text="Bo loc" />
                        </HBox>
                    </VBox>

                    <!-- ── Noi dung chinh ─────────────────── -->
                    <VBox spacing="32" style="-fx-padding: 24 24 32 24;">

                        <!-- ════ SECTION 1: San pham dang dau gia ════ -->
                        <VBox spacing="14">
                            <HBox alignment="CENTER_LEFT">
                                <Label text="San pham dang dau gia">
                                    <font><Font name="System Bold" size="18.0" /></font>
                                </Label>
                                <Region HBox.hgrow="ALWAYS" />
                                <Hyperlink onAction="#handleViewAll" style="-fx-text-fill: #3498db; -fx-font-size: 13;" text="Xem tat ca &gt;" />
                            </HBox>

                            <!-- Vung chua card san pham (Grid) -->
                            <FlowPane fx:id="itemGridPane" hgap="16" vgap="20">
                                <!-- Card se duoc render dong tu Controller -->
                            </FlowPane>
                        </VBox>

                        <!-- ════ SECTION 2: Nha ban hang noi bat ════ -->
                        <VBox spacing="14">
                            <HBox alignment="CENTER_LEFT">
                                <Label text="Nha ban hang noi bat">
                                    <font><Font name="System Bold" size="18.0" /></font>
                                </Label>
                                <Region HBox.hgrow="ALWAYS" />
                                <Hyperlink onAction="#handleViewAllSellers" style="-fx-text-fill: #3498db; -fx-font-size: 13;" text="Xem tat ca &gt;" />
                            </HBox>

                            <FlowPane fx:id="sellersGridPane" hgap="16" vgap="20">
                                <!-- Seller cards will be rendered dynamically -->
                            </FlowPane>
                        </VBox>

                        <!-- ════ SECTION 3: Tai san sap dau gia ════ -->
                        <VBox spacing="14">
                            <Label text="Tai san sap dau gia">
                                <font><Font name="System Bold" size="18.0" /></font>
                            </Label>

                            <FlowPane fx:id="upcomingGridPane" hgap="16" vgap="20">
                                <!-- Upcoming cards will be rendered dynamically -->
                            </FlowPane>
                        </VBox>

                    </VBox>
                </VBox>
            </ScrollPane>


        </HBox>
    </center>

</BorderPane>
