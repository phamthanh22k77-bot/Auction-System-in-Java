<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: #F5F5F5;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.bidder.AuctionListController">

    <!-- ===== TOP BAR ===== -->
    <top>
        <VBox style="-fx-background-color: #1A237E; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.3),8,0,0,2);">
            <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-padding: 12 20 12 20;">
                <Label style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" text="🏷 AUCTION PRO" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblUsername" style="-fx-text-fill: #90CAF9; -fx-font-size: 13;" text="Xin chào, Bidder" />
                <Button fx:id="btnLogout" onAction="#handleLogout" style="-fx-background-color: transparent; -fx-text-fill: #EF9A9A;                                -fx-border-color: #EF9A9A; -fx-border-radius: 4; -fx-cursor: hand;                                -fx-padding: 4 12;" text="Đăng xuất" />
            </HBox>

            <!-- Search + Filter bar -->
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 20 12 20;">
                <TextField fx:id="txtSearch" onAction="#handleSearch" promptText="🔍  Tìm kiếm phiên đấu giá..." style="-fx-pref-width: 340; -fx-background-color: #283593;                                   -fx-text-fill: white; -fx-prompt-text-fill: #9FA8DA;                                   -fx-border-color: #5C6BC0; -fx-border-radius: 6;                                   -fx-background-radius: 6; -fx-padding: 7 12;" HBox.hgrow="ALWAYS" />
                <ComboBox fx:id="cmbCategory" onAction="#handleFilter" promptText="Danh mục" style="-fx-background-color: #283593; -fx-text-fill: white;                                  -fx-border-color: #5C6BC0; -fx-border-radius: 6;                                  -fx-background-radius: 6;">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Tất cả" />
                            <String fx:value="Electronics" />
                            <String fx:value="Art" />
                            <String fx:value="Vehicle" />
                        </FXCollections>
                    </items>
                </ComboBox>
                <ComboBox fx:id="cmbStatus" onAction="#handleFilter" promptText="Trạng thái" style="-fx-background-color: #283593; -fx-text-fill: white;                                  -fx-border-color: #5C6BC0; -fx-border-radius: 6;                                  -fx-background-radius: 6;">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Tất cả" />
                            <String fx:value="RUNNING" />
                            <String fx:value="OPEN" />
                            <String fx:value="FINISHED" />
                        </FXCollections>
                    </items>
                </ComboBox>
                <Button onAction="#handleSearch" style="-fx-background-color: #42A5F5; -fx-text-fill: white;                                -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 7 18;" text="Tìm" />
            </HBox>
        </VBox>
    </top>

    <!-- ===== CENTER: TABLE ===== -->
    <center>
        <VBox style="-fx-padding: 16;">
            <!-- Summary row -->
            <HBox spacing="12" style="-fx-padding: 0 0 12 0;">
                <Label fx:id="lblTotalAuctions" style="-fx-text-fill: #616161; -fx-font-size: 13;" text="Đang hiển thị: 0 phiên" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#handleRefresh" style="-fx-background-color: transparent; -fx-text-fill: #1565C0;                                -fx-cursor: hand; -fx-font-size: 13;" text="↻ Làm mới" />
            </HBox>

            <!-- Table -->
            <TableView fx:id="tblAuctions" onMouseClicked="#handleRowDoubleClick" style="-fx-background-color: white;                               -fx-border-color: #E0E0E0; -fx-border-radius: 8;                               -fx-background-radius: 8;" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colAuctionId" prefWidth="80" text="Mã" />
                    <TableColumn fx:id="colItemName" prefWidth="220" text="Sản phẩm" />
                    <TableColumn fx:id="colCategory" prefWidth="110" text="Danh mục" />
                    <TableColumn fx:id="colStartPrice" prefWidth="110" text="Giá khởi" />
                    <TableColumn fx:id="colCurPrice" prefWidth="120" text="Giá hiện tại" />
                    <TableColumn fx:id="colEndTime" prefWidth="150" text="Kết thúc" />
                    <TableColumn fx:id="colStatus" prefWidth="100" text="Trạng thái" />
                </columns>
                <placeholder>
                    <Label style="-fx-text-fill: #9E9E9E; -fx-font-size: 14;" text="Không có phiên đấu giá nào." />
                </placeholder>
            </TableView>
        </VBox>
    </center>

    <!-- ===== BOTTOM BAR ===== -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-padding: 10 20; -fx-background-color: white;                      -fx-border-color: #E0E0E0; -fx-border-width: 1 0 0 0;">
            <Label fx:id="lblBalance" style="-fx-text-fill: #388E3C; -fx-font-weight: bold; -fx-font-size: 14;" text="Số dư: 0 ₫" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnViewDetail" onAction="#handleViewDetail" style="-fx-background-color: #1A237E; -fx-text-fill: white;                            -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 8 20;                            -fx-font-size: 13;" text="Xem chi tiết →" />
        </HBox>
    </bottom>
</BorderPane>
