<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
    BiddingScreen.fxml  —  LIGHT THEME
    Controller: controllers.bidder.BiddingController  (KHONG THAY DOI)

    Tat ca fx:id giu nguyen:
      lblItemName, lblLiveIndicator, lblBalance
      lblCurrentPrice, lblHighestBidder, lblCountdown
      lblCategory, lblSeller, lblStartPrice, lblEndTime
      listLiveBids
      chartBidHistory, axisTime, axisPrice   <- tuong thich BidPriceLineChart
      btnQuick1, btnQuick2, btnQuick3, btnQuick4
      txtBidAmount, btnPlaceBid, lblBidFeedback

    Thay doi:
      - Toan bo mau nen: dark #0D1B2A -> light #F5F6FA / white
      - Quick bid: +10k/+50k/+100k/+500k -> +100k/+500k/+1tr/+5tr

    BidPriceLineChart su dung:
      BidPriceLineChart bidChart =
          new BidPriceLineChart(chartBidHistory, axisTime, axisPrice);
      bidChart.addBidPoint(17_500_000);
-->

<BorderPane
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="controllers.bidder.BiddingController"
    style="-fx-background-color: #F5F6FA;">

    <!-- ══ TOP BAR ════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #FFFFFF;
                     -fx-padding: 10 20;
                     -fx-border-color: #E8ECF0; -fx-border-width: 0 0 1 0;
                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),4,0,0,2);">

            <Button text="← Quay lại" onAction="#handleBack"
                    style="-fx-background-color: transparent; -fx-text-fill: #2980B9;
                           -fx-cursor: hand; -fx-font-size: 13;"/>
            <Label text="|" style="-fx-text-fill: #DDE1E7;"/>

            <Label fx:id="lblItemName" text="Phiên đấu giá"
                   style="-fx-text-fill: #2C3E50; -fx-font-size: 15; -fx-font-weight: bold;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Live indicator -->
            <HBox alignment="CENTER" spacing="6"
                  style="-fx-background-color: #E9F7EF; -fx-background-radius: 20;
                         -fx-padding: 4 12;">
                <Label fx:id="lblLiveIndicator" text="●"
                       style="-fx-text-fill: #27AE60; -fx-font-size: 9;"/>
                <Label text="TRỰC TIẾP"
                       style="-fx-text-fill: #27AE60; -fx-font-size: 11; -fx-font-weight: bold;"/>
            </HBox>

            <!-- So du -->
            <VBox alignment="CENTER_RIGHT" style="-fx-padding: 0 0 0 12;">
                <Label text="Số dư của bạn"
                       style="-fx-text-fill: #95A5A6; -fx-font-size: 10;"/>
                <Label fx:id="lblBalance" text="0 đ"
                       style="-fx-text-fill: #27AE60; -fx-font-size: 14; -fx-font-weight: bold;"/>
            </VBox>
        </HBox>
    </top>

    <!-- ══ CENTER: 2 cot ═══════════════════════════════════ -->
    <center>
        <HBox spacing="0">

            <!-- ── LEFT PANEL: Thong tin phien + live feed ── -->
            <VBox prefWidth="290" spacing="0"
                  style="-fx-background-color: #FFFFFF;
                         -fx-border-color: #E8ECF0; -fx-border-width: 0 1 0 0;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.04),4,0,0,0);">

                <!-- Gia hien tai -->
                <VBox alignment="CENTER" spacing="6"
                      style="-fx-padding: 20 16;
                             -fx-background-color: #EBF5FB;
                             -fx-border-color: #D6EAF8; -fx-border-width: 0 0 1 0;">
                    <Label text="GIÁ HIỆN TẠI"
                           style="-fx-text-fill: #1A5276; -fx-font-size: 11;
                                  -fx-font-weight: bold;"/>
                    <Label fx:id="lblCurrentPrice" text="0 đ"
                           style="-fx-text-fill: #E74C3C; -fx-font-size: 32;
                                  -fx-font-weight: bold;"/>
                    <Label fx:id="lblHighestBidder" text="— chưa có lượt đặt"
                           style="-fx-text-fill: #5D6D7E; -fx-font-size: 12;"/>
                </VBox>

                <!-- Dem nguoc -->
                <HBox alignment="CENTER" spacing="10"
                      style="-fx-padding: 12 16;
                             -fx-background-color: #FEF9E7;
                             -fx-border-color: #FDEBD0; -fx-border-width: 0 0 1 0;">
                    <Label text="⏱" style="-fx-font-size: 16;"/>
                    <Label fx:id="lblCountdown" text="00 : 00 : 00"
                           style="-fx-text-fill: #D35400; -fx-font-size: 22;
                                  -fx-font-weight: bold;"/>
                </HBox>

                <!-- Thong tin san pham -->
                <VBox spacing="7"
                      style="-fx-padding: 14 16;
                             -fx-border-color: #E8ECF0; -fx-border-width: 0 0 1 0;">
                    <Label fx:id="lblCategory" text="Danh mục: —"
                           style="-fx-text-fill: #5D6D7E; -fx-font-size: 12;"/>
                    <Label fx:id="lblSeller" text="Người bán: —"
                           style="-fx-text-fill: #5D6D7E; -fx-font-size: 12;"/>
                    <Label fx:id="lblStartPrice" text="Giá khởi: —"
                           style="-fx-text-fill: #5D6D7E; -fx-font-size: 12;"/>
                    <Label fx:id="lblEndTime" text="Kết thúc: —"
                           style="-fx-text-fill: #5D6D7E; -fx-font-size: 12;"/>
                </VBox>

                <!-- Live bid feed -->
                <VBox spacing="8" VBox.vgrow="ALWAYS" style="-fx-padding: 14 16;">
                    <Label text="Lượt đặt giá trực tiếp"
                           style="-fx-text-fill: #2C3E50; -fx-font-size: 12;
                                  -fx-font-weight: bold;"/>
                    <!--
                        listLiveBids: controller them dong moi nhat len dau:
                          listLiveBids.getItems().add(0, "17:50:05  user_abc  17,500,000 d")
                    -->
                    <ListView fx:id="listLiveBids" VBox.vgrow="ALWAYS"
                              style="-fx-background-color: #F8F9FA;
                                     -fx-border-color: #E8ECF0; -fx-border-radius: 8;
                                     -fx-background-radius: 8; -fx-font-size: 12;"/>
                </VBox>
            </VBox>

            <!-- ── RIGHT PANEL: Chart + Nhap gia ─────────── -->
            <VBox spacing="0" HBox.hgrow="ALWAYS">

                <!-- LineChart gia dat theo thoi gian -->
                <!--
                    TUONG THICH BIDPRICELINECHART:
                      Controller khoi tao 1 lan trong initialize():
                        BidPriceLineChart bidChart =
                            new BidPriceLineChart(chartBidHistory, axisTime, axisPrice);
                        bidChart.setMaxPoints(20);

                      Moi khi co bid moi (onBidUpdate tu server):
                        Platform.runLater(() -> bidChart.addBidPoint(newPrice));

                      Load lich su khi mo man hinh:
                        bidChart.loadHistory(auction.getBidHistory());

                    3 fx:id can thiet: chartBidHistory, axisTime, axisPrice
                    -> Tat ca deu co trong file nay, KHONG can sua Controller.
                -->
                <VBox spacing="10" VBox.vgrow="ALWAYS"
                      style="-fx-padding: 16; -fx-background-color: #F5F6FA;">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Biểu đồ giá đấu theo thời gian"
                               style="-fx-text-fill: #2C3E50; -fx-font-size: 13;
                                      -fx-font-weight: bold;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Trục X: thời gian  |  Trục Y: giá (₫)"
                               style="-fx-text-fill: #95A5A6; -fx-font-size: 11;"/>
                    </HBox>

                    <LineChart fx:id="chartBidHistory"
                               VBox.vgrow="ALWAYS"
                               animated="true"
                               createSymbols="true"
                               style="-fx-background-color: white;
                                      -fx-border-color: #E8ECF0; -fx-border-radius: 10;
                                      -fx-background-radius: 10;
                                      -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.05),6,0,0,2);">
                        <xAxis>
                            <!--
                                CategoryAxis: nhan la string timestamp "HH:mm:ss"
                                BidPriceLineChart.addBidPoint() tu dong tao nhan nay
                            -->
                            <CategoryAxis fx:id="axisTime"
                                          label="Thời gian"
                                          style="-fx-tick-label-fill: #95A5A6;
                                                 -fx-font-size: 11;"/>
                        </xAxis>
                        <yAxis>
                            <!--
                                NumberAxis: gia dat (double)
                                BidPriceLineChart dat forceZeroInRange=false
                                -> truc Y tu tinh theo du lieu, khong bat dau tu 0
                            -->
                            <NumberAxis fx:id="axisPrice"
                                        label="Giá (₫)"
                                        style="-fx-tick-label-fill: #95A5A6;
                                               -fx-font-size: 11;"/>
                        </yAxis>
                    </LineChart>
                </VBox>

                <!-- Nhap gia + dat gia -->
                <VBox spacing="12"
                      style="-fx-background-color: #FFFFFF; -fx-padding: 16;
                             -fx-border-color: #E8ECF0; -fx-border-width: 1 0 0 0;
                             -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.04),4,0,-2,0);">

                    <HBox alignment="CENTER_LEFT">
                        <Label text="Đặt giá của bạn"
                               style="-fx-text-fill: #2C3E50; -fx-font-weight: bold;
                                      -fx-font-size: 14;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Tối thiểu phải cao hơn giá hiện tại"
                               style="-fx-text-fill: #95A5A6; -fx-font-size: 11;"/>
                    </HBox>

                    <!-- Quick bid: +100k / +500k / +1tr / +5tr -->
                    <!--
                        fx:id giu nguyen: btnQuick1, btnQuick2, btnQuick3, btnQuick4
                        Controller doc text cua tung nut de tinh step:
                          "+100k" -> 100_000
                          "+500k" -> 500_000
                          "+1tr"  -> 1_000_000
                          "+5tr"  -> 5_000_000
                    -->
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Tăng nhanh:"
                               style="-fx-text-fill: #95A5A6; -fx-font-size: 12;"/>
                        <Button fx:id="btnQuick1" text="+100k" onAction="#handleQuickBid"
                                style="-fx-background-color: #EBF5FB; -fx-text-fill: #1A5276;
                                       -fx-border-color: #AED6F1; -fx-border-radius: 20;
                                       -fx-background-radius: 20; -fx-cursor: hand;
                                       -fx-padding: 5 14; -fx-font-size: 12;"/>
                        <Button fx:id="btnQuick2" text="+500k" onAction="#handleQuickBid"
                                style="-fx-background-color: #EBF5FB; -fx-text-fill: #1A5276;
                                       -fx-border-color: #AED6F1; -fx-border-radius: 20;
                                       -fx-background-radius: 20; -fx-cursor: hand;
                                       -fx-padding: 5 14; -fx-font-size: 12;"/>
                        <Button fx:id="btnQuick3" text="+1tr" onAction="#handleQuickBid"
                                style="-fx-background-color: #EBF5FB; -fx-text-fill: #1A5276;
                                       -fx-border-color: #AED6F1; -fx-border-radius: 20;
                                       -fx-background-radius: 20; -fx-cursor: hand;
                                       -fx-padding: 5 14; -fx-font-size: 12;"/>
                        <Button fx:id="btnQuick4" text="+5tr" onAction="#handleQuickBid"
                                style="-fx-background-color: #EBF5FB; -fx-text-fill: #1A5276;
                                       -fx-border-color: #AED6F1; -fx-border-radius: 20;
                                       -fx-background-radius: 20; -fx-cursor: hand;
                                       -fx-padding: 5 14; -fx-font-size: 12;"/>
                    </HBox>

                    <!-- O nhap + nut dat gia -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="txtBidAmount"
                                   promptText="Nhập số tiền (₫)"
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-color: #F8F9FA;
                                          -fx-text-fill: #2C3E50;
                                          -fx-prompt-text-fill: #BDC3C7;
                                          -fx-border-color: #DDE1E7; -fx-border-radius: 8;
                                          -fx-background-radius: 8;
                                          -fx-padding: 11 14; -fx-font-size: 16;
                                          -fx-font-weight: bold;"/>
                        <Button fx:id="btnPlaceBid"
                                text="ĐẶT GIÁ"
                                onAction="#handlePlaceBid"
                                prefHeight="44"
                                style="-fx-background-color: #E74C3C; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-font-size: 14;
                                       -fx-background-radius: 8; -fx-cursor: hand;
                                       -fx-padding: 0 28;
                                       -fx-effect: dropshadow(gaussian,rgba(231,76,60,0.35),8,0,0,2);"/>
                    </HBox>

                    <!-- Feedback -->
                    <Label fx:id="lblBidFeedback" text="" wrapText="true"
                           style="-fx-font-size: 12;"/>
                </VBox>

            </VBox>
        </HBox>
    </center>

</BorderPane>
